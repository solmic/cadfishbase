	volume = {30},
	issn = {13001590, 21474303},
	url = {http://www.egejfas.org/issue/4987/67575},
	doi = {10.12714/egejfas.2013.30.2.03},
	abstract = {The diets of five deep sea fish: Argentina sphyraena, Glossanodon leioglossus, Chlorophthalmus agassizi, Hoplostethus mediterraneus and Capros aper from the Aegean Sea were examined in the specimens caught as bycatch and discarded by commercial trawl fisheries during 2003 spring. Stomach contents were analyzed to determine their diet composition, which indicates that the trophic status of these species can be assigned primarily to the carnivore guild. Two major prey groups were found in the diet composition of all five predators: Crustaceans (like copepods and isopods), and Chaetognathans (Sagitta spp.).},
