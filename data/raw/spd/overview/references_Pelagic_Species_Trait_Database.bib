@article{techaratanakrai_effect_2011,
	title = {Effect of setting conditions on mechanical properties of acid-induced {Kamaboko} gel from squid \textit{{Todarodes} pacificus} mantle muscle meat},
	volume = {77},
	issn = {0919-9268, 1444-2906},
	url = {http://link.springer.com/10.1007/s12562-011-0344-9},
	doi = {10.1007/s12562-011-0344-9},
	abstract = {Squid Todarodes paciﬁcus suwari gels, set at various temperatures and times, and acid-induced kamaboko gel, which was prepared by soaking suwari gel in 5\% acetic acid for 20 h, were studied to evaluate the mechanical properties that are affected by setting conditions. Unset squid meat paste did not form a gel when soaked in acetic acid. The breaking strength of both suwari gel and acid-induced kamaboko gel showed a tendency to increase with setting temperature and time. SDS-PAGE analysis of suwari gel and acid-induced kamaboko gel, which were set at various temperatures and times, showed that myosin heavy chain (MHC) was observed at 30°C only for the ﬁrst hour. The intensity of the MHC band at 30°C gradually decreased with setting time, while the intensity of the polymer band gradually increased with setting time. These results suggest that the protein-protein bonds in suwari gel affect the ﬁnal texture of acid-induced kamaboko gel. Based on the analysis of the mechanical properties, and in consideration of the fact that the purpose of this experiment was to reduce energy usage, the best setting condition was determined to be 40°C for 3 h.},
	language = {en},
	number = {3},
	urldate = {2023-05-08},
	journal = {Fisheries Science},
	author = {Techaratanakrai, Bodin and Nishida, Moemi and Igarashi, Yuki and Watanabe, Manabu and Okazaki, Emiko and Osako, Kazufumi},
	month = may,
	year = {2011},
	note = {Number: 3},
	pages = {439--446},
}

