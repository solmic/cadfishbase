@article{locke_amphipods_1989,
	title = {Amphipods, isopods and surface currents: a case for passive dispersal in the {Bay} of {Fundy}, {Canada}},
	volume = {11},
	issn = {0142-7873, 1464-3774},
	shorttitle = {Amphipods, isopods and surface currents},
	url = {https://academic.oup.com/plankt/article-lookup/doi/10.1093/plankt/11.3.419},
	doi = {10.1093/plankt/11.3.419},
	abstract = {Six species of isopods and 18 species of amphipods were collected in the neuston of the Bay of Fundy and adjacent waters. Collections were made over a grid of stations covering 2.4 x 104 km during three spring, three summer and two autumn surveys. No isopods and only five species of amphipods were found in spring surveys. Isopods and amphipods were diverse and plentiful in the neuston in summer and autumn. Dominant isopods were Idotca baltica and I.metallica, and dominant amphipods were Callicpius laeviusculus and Parathemisto gaudichaudi. Amphipods and isopods reach the neuston of the Bay of Fundy in three ways. Idotea metallica, the only euneustonic species present, was probably adverted into the Bay of Fundy from southern waters in summer, and did not appear to overwinter in the Bay. Most species, including I.baltica, were collected with drifting littoral vegetation, and we suggest that transport by surface currents is an important factor in dispersal of some shoreline crustaceans. Midwater plankton, such as Parathemisto gaudichaudi, reached the neuston either by advection in upwelling waters or by an extension of their normal diel vertical distribution.},
	language = {en},
	number = {3},
	urldate = {2023-07-25},
	journal = {Journal of Plankton Research},
	author = {Locke, A. and Corey, S.},
	year = {1989},
	note = {Number: 3},
	pages = {419--430},
}

@article{olivar_transitory_1998,
	title = {Transitory hydrographic structures and distribution of fish larvae and neustonic crustaceans in the north-western {Mediterranean}},
	volume = {21},
	issn = {0399-1784},
	url = {https://www.sciencedirect.com/science/article/pii/S0399178498800534},
	doi = {10.1016/S0399-1784(98)80053-4},
	abstract = {A hydrographic and zooplankton survey (neuston and water column) was performed over the Blanes submarine canyon (western Mediterranean) in June 1993. Abundance of fish and crab larvae was very low when compared with previous studies conducted in the same area. The horizontal distribution of fish and crab larvae whose adults inhabit the continental shelf was restricted to the coast. The offshore occurrence of low-salinity waters of continental origin, together with the absence of a component perpendicular to the coast in the system of currents observed throughout the study area, support the observed pattern of distribution. The occurrence of mesopelagic fish larvae and of the oceanic neustonic isopod Idotea metallica in some coastal stations may be associated with episodic inshore-offshore exchanges of water masses identified by drifting buoy trajectories.
Résumé
L'hydrologie et le zooplancton (dans le neuston et la colonne d'eau) ont étéétudiés en juin 1993 sur le canyon sous-marin de Blanes en Méditerranée nord-occidentale. L'abondance des larves de poissons et des crustacés du neuston est très inférieure à celle qui a été mesurée précédemment. La répartition horizontale des larves est limitée aux eaux côtières lorsque les adultes habitent le plateau continental. La présence au large d'eaux peu salées d'origine continentale et l'absence d'une composante perpendiculaire à la côte dans le système des courants confirme le schéma de répartition observé. La présence de quelques larves de poissons mésopélagiques et de l'isopode océanique Idotea metallica en plusieurs stations côtières peut être associée aux échanges épisodiques d'eaux côtières et océaniques identifiés par les trajectoires de bouées dérivantes.},
	language = {en},
	number = {1},
	urldate = {2023-07-25},
	journal = {Oceanologica Acta},
	author = {Olivar, M. Pilar and Sabates, Ana and Abello, Pere and Garcia, Marc},
	month = jan,
	year = {1998},
	note = {Number: 1},
	pages = {95--104},
}

@article{abitia-cardenas_diet_1999,
	title = {Diet of blue marlin \textit{{Makaira} mazara} off the coast of {Cabo} {San} {Lucas}, {Baja} {California} {Sur}, {Mexico}},
