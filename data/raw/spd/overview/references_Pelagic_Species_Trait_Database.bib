@article{akbardiansyah_karakteristik_2018,
	title = {Karakteristik {Ikan} {Asin} {Kambing}-{Kambing} (\textit{{Canthidermis} maculata}) {Dengan} {Penggaraman} {Kering}},
	volume = {21},
	issn = {2354-886X, 2303-2111},
