@article{colton_aspects_2007,
	title = {Aspects of the life history of treefish, \textit{{Sebastes} serriceps} ({Sebastidae})},
	volume = {48},
	url = {https://www.researchgate.net/profile/Dianna-Porzio/publication/298858598_Review_of_some_California_fisheries_for_2006_Coastal_pelagic_finfish_market_squid_Dungeness_crab_spot_prawn_highly_migratory_species_ocean_salmon_California_halibut_nearshore_live-fishes_cabezon_surfp/links/5f401790458515b7293c6e66/Review-of-some-California-fisheries-for-2006-Coastal-pelagic-finfish-market-squid-Dungeness-crab-spot-prawn-highly-migratory-species-ocean-salmon-California-halibut-nearshore-live-fishes-cabez.pdf#page=177},
	abstract = {In this paper, we report the reproductive seasonality, maturity, length-age and length-weight relationships, and the parameters for converting between total and standard lengths for Sebastes serriceps from the Southern California Bight. Our data indicate that the von Bertalanffy age-length parameters are L∞ = 30.64 cm, k = 0.233, and t0 = –1.167. Females were reproductively active between at least February and May, and ovaries were found to contain eyed larvae in March. Males were reproductively active between October and at least December. The oldest fish we collected was 25 years of age; the age at 50\% maturity was 4 years for females and 3 years for males; and the total length at 50\% maturity was 19.0 to 19.9 cm for both sexes. We found no evidence of sexual dimorphism in mean length, growth, or the length-weight relationship. These findings are consistent with the life history traits of ecologically similar species of Sebastes.},
	language = {en},
	journal = {CalCOFI Report},
	author = {Colton, Madhavi A. and Larson, Ralph J.},
	year = {2007},
	pages = {177--190},
}

