	note = {Number: 3},
	pages = {499--512},
}

@article{thangaraja_spawning_2011,
	title = {On the spawning periodicity and early embryonic and larval stages of six species of fishes of the waters of {Sultanate} of {Oman}},
	volume = {3},
	url = {https://www.researchgate.net/profile/Thangaraja_Muthian/publication/236163720_On_the_spawning_periodicity_and_early_embryonic_and_larval_stages_of_six_species_of_fishes_of_the_waters_of_Sultanate_of_Oman/data/00b49516a608f4bb7c000000/fish-larvae-paper.pdf},
	abstract = {The eggs of six species of fishes have been collected from the wild, reared in the laboratory and identified. The collected fertilized eggs have been grown from embryonic to post larval stages and each stage is described with photographic illustration and discussed. The species include: Sardinella sp. (4 stages); Trachinocephalus myops (7 stages); Microchirus (= Solea) variegatus (7 stages); Fistularia sp. (11 stages); Trachurus indicus (7 stages) and Ostracion cubicus (4 stages). Spawning period of all the six species have been predicted with varying degrees of certainty. The possible spawning period of these species extended as follows: Sardinella sp. in April, July – November and January in the Sea of Oman (Gulf of Oman) and the Arabian Sea; T. myops in nine months except in March, June and July in the Sea of Oman; M. variegatus in July to October in the Sea of Oman; Fistularia sp. in all months except in May in the Sea of Oman and the Arabian Sea; T. indicus in September in the Sea of Oman; and O. cubicus in July in the Sea of Oman.},
	language = {en},
	number = {1-2},
	journal = {South Indian Coastal and Marine Bulletin},
	author = {Thangaraja, M. and Al-Aisry, Ahmed},
	year = {2011},
	note = {Number: 1-2},
	pages = {14--21},
}

