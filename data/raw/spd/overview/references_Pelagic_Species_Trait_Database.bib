@article{evseenko_early_1995,
	title = {Early {Stages} of {Development} of {Rare} {Deepwater} {Fishes} from {Notal} {Waters} of the {Southwestern} {Pacific}},
	volume = {35},
	url = {https://www.researchgate.net/profile/Sergei-Evseenko/publication/277005391_Early_Stages_of_Development_of_Rare_Deepwater_Fishes_from_Notal_Waters_of_the_Southwestern_Pacific/links/555d668708ae8c0cab2ad256/Early-Stages-of-Development-of-Rare-Deepwater-Fishes-from-Notal-Waters-of-the-Southwestern-Pacific.pdf},
	abstract = {Illustrated descriptions of previously unknown stages of the development of four species of rare deepwater fishes from notal waters of the southwestern Pacific are presented: Agrostichthys parkeri (Regalecidae), Dolichopteryx longipes and
Opisthoproctus soleatus (Opisthoproctidae), and Woodsia meyerwaardeni (Photichthidae).
A W. nonsuchae larva from the central-western waters of the Pacific Ocean
is also described for comparison with W. meyerwaardeni larvae. The A. parkeri prefingerling
is distinguished from the holotype of this species (adult) on the basis of the
presence of a caudal fin, which is probably explained by its complete reduction
during ontogeny of Agrostichthys. The identification of D. longipes and O. soleatus
larvae is based on the correspondence of their meristic characters. Information available
in the literature regarding differences between the species of each of the genera
is based on a limited amount of material. Therefore our identifications of the larvae
of both species are tentative. The W. meyerwaardeni and W. nonsuchae larvae are
clearly distinguished on the basis of the characteristics of the pigmentation of the
body and on the basis of the relative length of the rays in the dorsal and anal fins.},
	number = {8},
	journal = {Journal of Ichthyology},
	author = {Evseenko, S. A. and Suntsov, A. V.},
	month = jan,
	year = {1995},
	note = {Number: 8},
	pages = {111--122},
}

@article{fang_sexual_2016,
	title = {Sexual asynchrony in the development of beak pigmentation for the neon flying squid \textit{{Ommastrephes} bartramii} in the {North} {Pacific} {Ocean}},
	volume = {82},
	issn = {1444-2906},
	url = {https://doi.org/10.1007/s12562-016-1011-y},
	doi = {10.1007/s12562-016-1011-y},
	abstract = {The squid beak is a hard structure that displays high variability in both shape and coloring and can contain valuable ecological information. The beak pigmentation process reflects changes in growth and diet. In this study, we proposed species–specific beak pigmentation stages (PS) to supplement a previous classification scheme, which quantifies beak growth based on pigmentation variability. We analyzed sexual differences for Ommastrephes bartramii in the North Pacific Ocean. Distribution of beak PS increased with mantle length (ML). Body and beak measurements and beak weight were significantly different between PSs for both sexes. The relationship between ML and beak measurements differed significantly between the sexes. The observed differences might result from variable growth in different habitats as a result of sex-segregated migration in the North Pacific Ocean. The process of beak pigmentation may reflect variability in growth associated with different feeding regimes. The sexual asynchrony of pigmentation can also give us a supplemental way to discriminate different sexes using beak morphometric.},
	language = {en},
	number = {5},
	urldate = {2023-08-18},
	journal = {Fisheries Science},
	author = {Fang, Zhou and Liu, Bilin and Chen, Xinjun and Jin, Yue and Li, Jianhua and Chen, Yong},
	month = sep,
	year = {2016},
	note = {Number: 5},
	keywords = {Beak, North Pacific ocean, Ommastrephes bartramii, Pigmentation, Sexual asynchrony},
	pages = {737--746},
}

@article{farrag_deep-sea_2016,
	title = {Deep-sea ichthyofauna from {Eastern} {Mediterranean} {Sea}, {Egypt}: {Update} and new records},
	volume = {42},
	issn = {1687-4285},
	shorttitle = {Deep-sea ichthyofauna from {Eastern} {Mediterranean} {Sea}, {Egypt}},
	url = {https://www.sciencedirect.com/science/article/pii/S1687428516300905},
	doi = {10.1016/j.ejar.2016.12.005},
	abstract = {This work sheds light on deep sea resources that update the list of deep sea ichthyoids fauna with new records from the Egyptian coast, Mediterranean Sea. Fish samples were collected from April to November 2015 at depths of 350–750m using deep red shrimp bottom trawlers. The presented fauna were constituted mainly of deep red shrimp (Aristeomorpha folicea and Aristeus antennatus) as target species followed by by-catch and discards which were represented by 36 fish species; Of them, 21 species were recorded previously. The rest of the species, were new ichthyofauna identified in fifteen species including 4 cartilaginous species (Centrophorus uyato, Etmopterus spinax, Hydrolagus mirabilis and Chimaera monstrosa), while the other 11 species were bony fishes (Chauliodus sloani, Diaphus metopoclampus, Sudis hyaline, Microstoma microstoma, Chlorophthalmus agassizi, Avocettina infans, Argyropelecus hemigymnus, Notacanthus bonaparte, Lampanyctus crocodilus, Centrolophus niger and Nettastoma melanurum). Centrophorus uyato was reported for the first time in the Levant Basin. The present findings added new species to the Egyptian ichthyofauna and raised the total known deep water fauna to 38 species, enhancing knowledge about such species requires continuous monitoring and studies on deep sea resources.},
	number = {4},
	urldate = {2023-08-18},
	journal = {The Egyptian Journal of Aquatic Research},
	author = {Farrag, Mahmoud M. S.},
	month = dec,
	year = {2016},
	note = {Number: 4},
	keywords = {Mediterranean Sea, Deep-sea ichthyofauna, Egypt, New records},
	pages = {479--489},
}

