	title = {New {Data} on {Proximate} {Composition} and {Energy} {Density} of {Steller} {Sea} {Lion} (\textit{{Eumetopias} jubatus}) {Prey} {Fills} {Seasonal} and {Geographic} {Gaps} in {Existing} {Information}},
