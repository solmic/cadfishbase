@article{thurston_vertical_1976,
	title = {The {Vertical} {Distribution} and {Diurnal} {Migration} of the {Crustacea} {Amphipoda} {Collected} during the {SOND} {Cruise}, 1965 {II}. {The} {Hyperiidea} and {General} {Discussion}},
