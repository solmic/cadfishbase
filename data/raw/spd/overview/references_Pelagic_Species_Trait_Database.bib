	volume = {127},
	issn = {00220981},
	url = {https://linkinghub.elsevier.com/retrieve/pii/0022098189900804},
	doi = {10.1016/0022-0981(89)90080-4},
	abstract = {The biochemic{\textasciitilde} com{\textasciitilde}sition of the leptomedusa Aequorea vktotia (Murbach et Shearer, 1902) was analysed in terms of protein, lipid, fatty acids, carbohydrates, and neutral sugars. These organic constituents formed {\textless} 10\% of the dry weight of the medusa in which the solids constituted only 2.8\% of the wet weight. The fatty acid composition of total lipids included a higher percentage of arachidonic acid than is usual in marine organisms. No significant changes in concentration of total protein, lipid, or carbohydrate were observed in short-term starvation although the content ofglucose in the polysaccharides declined and the proportion of saturated fatty acids in the Iipids increased slightly during the period of inanition.},
