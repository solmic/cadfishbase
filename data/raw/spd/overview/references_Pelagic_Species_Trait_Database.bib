	issn = {1323-1650},
	shorttitle = {Feeding ecology of {Macruronus} novaezelandiae ({Hector}) ({Teleostei}},
	url = {http://www.publish.csiro.au/?paper=MF9860621},
	doi = {10.1071/MF9860621},
	abstract = {The diet and feeding ecology of the demersal merlucciid M , novaezelandiae from three areas of the upper continental slope (420-550 m) of south-eastern Australia are described. The food consists almost entirely of mesopelagic fauna. The major prey are myctophid fish Lampanyctodes hectoris, other fishes, natant decapods, euphausiids and squid. Energy values of major prey items were determined by bomb calorimetry. Although euphausiids occur frequently in the diet, fish make up 90\% of the energy intake. There is little regional variation. M. novaezelandiae undertakes diel vertical migrations that are similar to those of its prey, bringing it within 50 m of the surface at night. There is a seasonal trend towards cannibalism by adults on juveniles.},
