@article{herring_depth_1972,
	title = {Depth {Distribution} of the {Carotenoid} {Pigments} and {Lipids} of {Some} {Oceanic} {Animals} 1. {Mixed} {Zooplankton}, {Copepods} and {Euphausiids}},
	volume = {52},
