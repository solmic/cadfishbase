@article{oliveira_chemical_2011,
	title = {Chemical composition of black rockfish (\textit{{Sebates} melanops}) fillets and byproducts: {Black} rockfish composition},
	volume = {35},
	issn = {01458892},
	shorttitle = {{CHEMICAL} {COMPOSITION} {OF} {BLACK} {ROCKFISH} ({SEBASTES} {MELANOPS}) {FILLETS} {AND} {BYPRODUCTS}},
	url = {https://onlinelibrary.wiley.com/doi/10.1111/j.1745-4549.2010.00489.x},
	doi = {10.1111/j.1745-4549.2010.00489.x},
	abstract = {Black rockﬁsh are important in the near shore ﬁshery of Southeast Alaska, being the only species among the pelagic shelf rockﬁshes with a directed ﬁshery in State waters. The purpose of this study was to determine the composition of black rockﬁsh ﬁllets, heads and livers. Fillet yields were low at 13.7\% of whole ﬁsh weight (WFW), while heads and livers composed 24.8 and 1.9\% of WFW, respectively. Byproducts were a valuable source of lipids, and the marine oils extracted from these tissues were similar in many aspects to oils from other cold water marine ﬁnﬁsh, being rich in omega-3 and low in omega-6 fatty acids. Protein content of ﬁllets, heads and livers were within the expected range (15–20\%). Amino acid analysis revealed that byproducts protein fractions were of high nutritional value.},
	language = {en},
	number = {4},
	urldate = {2023-05-08},
	journal = {Journal of Food Processing and Preservation},
	author = {Oliveira, Alexandra C.M. and Bechtel, Peter J. and Lapis, Trina J. and Brenner, Kathryn A. and Ellingson, Rhiannon},
	month = aug,
	year = {2011},
	note = {Number: 4},
	pages = {466--473},
}

@article{huynh_evaluating_2009,
	title = {Evaluating nutritional quality of pacific fish species from fatty acid signatures},
	volume = {114},
	issn = {03088146},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S0308814608012557},
	doi = {10.1016/j.foodchem.2008.10.038},
	abstract = {Eight ﬁsh species common to the Paciﬁc Northwest coastal waters were categorised according to total lipids in a ranking from lean ﬁsh (e.g. walleye pollock) to oily ﬁsh (e.g. herring) species. Comprehensive fatty acid signatures were compared on both the relative proportion of total fatty acids and the proportion of total carcass lipid content. Generally, ﬁsh species from the Paciﬁc coast had a relatively high proportion of n-3 highly polyunsaturated fatty acids (n-3 HUFAs), of which more than 80\% was accounted for by C20:5n-3 (EPA) and C22:6n-3 (DHA), with species-speciﬁc and lower proportions of oleic acid (C18:1n-9) and palmitic acid (C16:0) also dominating. The MUFA contents of ﬁsh were lower (P {\textless} 0.05) in the lipids of lean and low-fat ﬁsh compared to those of fattier species. In contrast, higher (P {\textless} 0.05) proportions of polyunsaturated fatty acids (PUFAs) existed in the low-fat species with DHA contents ranging from 18\% to 29\% in the low-fat ﬁsh and from 8\% to 10\% in the fattier ﬁsh, such as herring and capelin. Expressing the same fatty acid content data in terms of absolute amount of fatty acids (e.g. gFA/100 g wet tissue) showed that both EPA and DHA contents in the ﬂesh of pollock and hake were indeed many fold lower than those found in fatty ﬁsh, such as herring. The ﬁndings conﬁrm that it is important that both the total lipid content and the fatty acid composition of these Paciﬁc ﬁsh food sources be considered when making evaluations on the nutritional quality.},
	language = {en},
	number = {3},
	urldate = {2023-05-08},
	journal = {Food Chemistry},
	author = {Huynh, Minh Dieu and Kitts, David D.},
	month = jun,
	year = {2009},
	note = {Number: 3},
	pages = {912--918},
}

