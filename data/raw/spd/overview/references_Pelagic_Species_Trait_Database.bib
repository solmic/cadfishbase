@article{beacham_genetic_1988,
	title = {A genetic analysis of early development in pink (\textit{{Oncorhynchus} gorbuscha}) and chum salmon (\textit{{Oncorhynchus} keta}) at three different temperatures},
	volume = {30},
	issn = {0831-2796, 1480-3321},
	url = {http://www.nrcresearchpress.com/doi/10.1139/g88-015},
	doi = {10.1139/g88-015},
	abstract = {A factorial mating design was employed in which five males were mated to each of five females in each of two stocks for both pink and chum salmon. The resulting embryos and alevins were incubated at constant water temperatures of 4, 8, and 16 °C for pink salmon and 3, 8, and 15 °C for chum salmon. Variation among families in alevin and fry survival rates, hatching, button-up time, length, and weight was the least at 8 °C. Heritability of traits directly correlated with fitness, such as survival rates and button-up time, was low at all temperatures (h
              2
               ≤ 0.25). Maternal effects could account for a substantial portion of the variation in alevin and fry size characters. Nonadditive genetic variance accounted for more of the variation in fry size characters than in those of alevins. Negative genetic correlations were observed between embryo survival and subsequent alevin size and between hatching time and subsequent alevin and fry size. Genotype–temperature interactions could underlie a substantial amount of phenotypic variation in the developmental characters examined for both species.Key words: development, genetic variation, quantitative genetics, salmon.},
	language = {en},
	number = {1},
	urldate = {2023-08-17},
	journal = {Genome},
	author = {Beacham, Terry D.},
	month = feb,
	year = {1988},
	note = {Number: 1},
	pages = {89--96},
}

