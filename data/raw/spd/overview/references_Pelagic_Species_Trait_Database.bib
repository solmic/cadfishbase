@article{templeman_distributions_1966,
	title = {Distributions and {Comparisons} of \textit{{Centrolophus} niger} ({Gmelin}) and \textit{{Centrolophus} britannicus} {Günther} ({Centrolophidae}) from the {North} {Atlantic}},
	volume = {23},
	issn = {0015-296X},
	url = {https://cdnsciencepub.com/doi/10.1139/f66-108},
	doi = {10.1139/f66-108},
	abstract = {The general distribution of Centrolophus niger in the North Atlantic is reviewed including the first two records from the Canadian area and two additional records off the New England coast to add to the four previously recorded from this area. Two new records from the Dana collections extend the distribution of this species westward in the oceanic area between Iceland and the Azores. All known records of the rarely captured Centrolophus britannicus are presented. These include 34 previously published records from the northeastern Atlantic, eight new records from the northeastern Atlantic and the first seven records from the northwestern Atlantic, from Flemish Cap and the southern Grand Bank to North Carolina.In separating C. niger and C. britannicus some meristic characters are useful: C. niger, D. 35–41, A. 23–25, P. 20–23, gill-rakers on lower limb 1st arch, 13–15; C. britannicus, D. 44–51 (one, 55), A. 27–33 (one, 25), P. 18–21 (one, 16), gill-rakers on lower limb 1st arch, 11–13. Some body proportions are also important: the bases of the dorsal and anal fins are longer in C. britannicus and the distance from the snout to the anterior base of the dorsal fin usually greater. The length of the caudal peduncle is distinctly greater in C. niger.In C. niger the flesh is firm and the skin tough whereas in C. britannicus the flesh is flabby and the skin delicate. The peritoneum of C. britannicus is usually dark and that of C. niger usually light.},
	number = {8},
	urldate = {2023-08-16},
	journal = {Journal of the Fisheries Research Board of Canada},
	author = {Templeman, Wilfred and Haedrich, Richard L.},
	month = aug,
	year = {1966},
	note = {Number: 8
Publisher: NRC Research Press},
	pages = {1161--1185},
}

@article{laroche_development_1981,
	title = {Development of larvae and juveniles of the rockfishes \textit{{Sebastes} entomelas} and \textit{{S}. zacentrus} ({Family} {Scorpaenidae}) and occurrence off {Oregon}, with notes on head spines of \textit{{S}. mystinus}, \textit{{S}. flavidus}, and \textit{{S}. melanops}},
	volume = {79},
	url = {https://books.google.ca/books?hl=en&lr=&id=GYA0cHfbKvgC&oi=fnd&pg=PA231&dq=Sebastes+entomelas+juvenile+length&ots=6NEXXFYRLf&sig=6R0WoLwUYHaCdVWYN5S1aUuyCEs#v=onepage&q=Sebastes%20entomelas%20juvenile%20length&f=false},
