@article{tierney_energy_2002,
	title = {Energy content of mesopelagic fish from {Macquarie} {Island}},
	volume = {14},
	issn = {0954-1020, 1365-2079},
	url = {https://www.cambridge.org/core/product/identifier/S0954102002000020/type/journal_article},
	doi = {10.1017/S0954102002000020},
	abstract = {The water and calorific content of fifteen species of mesopelagic sub-Antarctic fish from Macquarie Island were determined. Mean percent water content was 69–82\%. Calorific content was highly variable between species, especially in the Myctophidae, where it ranged between 22.62–59.26 kJ g-1 dry weight. The water and calorific content varied with size class within a species, with the smallest size classes generally having the lowest water content but highest calorific content. These values will be useful for future assessment of energetic transfer between trophic levels and energetic modelling of Southern Ocean ecosystems.},
	language = {en},
	number = {3},
	urldate = {2023-05-08},
	journal = {Antarctic Science},
