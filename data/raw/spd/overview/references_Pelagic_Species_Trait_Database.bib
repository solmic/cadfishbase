	pages = {1--8},
}

@article{leong_growth_1984,
	title = {Growth of jack mackerel, \textit{{Trachurus} symmetricus}, in captivity},
	volume = {25},
	url = {https://calcofi.com/publications/calcofireports/v25/Vol_25_Leong.pdf},
	doi = {NA},
	abstract = {Fishery data indicate that jack mackerel captured from inshore waters are seldom more than 380 mm in fork length (FL). This laboratory study shows that the inshore fish have the potential to grow as large as 425-450 mm FL. During a 2-year period laboratoryheld mackerel grew more than three times faster in length and more than five times faster in weight than fish in the wild. Most of the surplus weight (65\%) was fat, but a significant portion (26\%) was fat-free dry weight, indicating that protein as well as fat was stored. The high levels of fat and protein accumulated by the laboratory fish indicate that the growth in length (skeletal growth) may have been near the maximum rate. The excess fat was deposited in the red and white muscles and viscera in different proportions.},
	language = {en},
	journal = {CalCOFI Reports},
