}

@article{johnson_distribution_2003,
	title = {Distribution, {Habitat}, and {Behavior} of {Rockfishes}, \textit{{Sebastes}} spp., in {Nearshore} {Waters} of {Southeastern} {Alaska}: {Observations} {From} a {Remotely} {Operated} {Vehicle}},
	volume = {66},
	issn = {1573-5133},
	shorttitle = {Distribution, {Habitat}, and {Behavior} of {Rockfishes}, {Sebastes} spp., in {Nearshore} {Waters} of {Southeastern} {Alaska}},
	url = {https://doi.org/10.1023/A:1023981908146},
	doi = {10.1023/A:1023981908146},
	abstract = {We examined distribution, habitat, and behavior of rockfishes, Sebastes spp., with a remotely operated vehicle (ROV) in coastal waters {\textless}90 m deep of southeastern Alaska from 1998 to 2000. We identified black, S. melanops, canary, S. pinniger, China, S. nebulosus, copper, S. caurinus, dusky, S. ciliatus, harlequin, S. variegatus, Puget Sound, S. emphaeus, quillback, S. maliger, redstripe, S. proriger, rosethorn, S. helvomaculatus, silvergray, S. brevispinis, tiger, S. nigrocinctus, yelloweye, S. ruberrimus, and yellowtail, S. flavidus, rockfish. Quillback and dusky rockfish were the most widely distributed species, China and harlequin rockfish were the least widely distributed species. Species richness was greater at sites on or near the outer coast than at sites in more inside, sheltered waters. Most ({\textgreater}75\%) observations of rockfish were over complex bottoms of boulder and rock or in vertical bedrock wall habitats. Few rockfish were observed over soft bottoms with no relief. Median depth of observation was ≤30 m for black, copper, dusky, and yellowtail rockfish and {\textgreater}30 m for all other species. Median temperature of observation ranged from 6.1°C for harlequin rockfish to 9.4°C for black rockfish. Size of fish was positively correlated (p ≤ 0.036) with depth for dusky, quillback, and yelloweye rockfish. Species often observed alone were China (67\%), copper (46\%), quillback (46\%), and rosethorn (43\%) rockfish. Most (≥70\%) observations of harlequin, Puget Sound, silvergray, tiger, and yelloweye rockfish were in mixed species assemblages. When first observed, the behavior of most rockfish species was swimming or hovering. Notable exceptions were China, harlequin, rosethorn, and tiger rockfish; 33–57\% were resting on bottom or in a hole or crevice.},
	language = {en},
	number = {3},
	urldate = {2023-08-31},
	journal = {Environmental Biology of Fishes},
	author = {Johnson, Scott W. and Murphy, Michael L. and Csepp, David J.},
	month = mar,
	year = {2003},
	note = {Number: 3},
	keywords = {temperature, depth, ROV, species associations, substrate},
	pages = {259--270},
}

@article{abe_chapter_2009,
	title = {Chapter 6 - {Adaptation} and {Evolution} of {Reproductive} {Mode} in {Copulating} {Cottoid} {Species}},
	volume = {8B},
	url = {https://www.taylorfrancis.com/chapters/edit/10.1201/9780429094170-6/adaptation-evolution-reproductive-mode-copulating-cottoid-species-takuzo-abe-hiroyuki-munehara},
	doi = {10.1201/9780429094170},
	abstract = {In this chapter, the authors review the diversity of the reproductive mode among cottoid fishes, and discuss the evolutionary process of copulation from the viewpoint of behavioral ecology. A basic copulatory behavior is exhibited in Clinocottus recalvus, where a male fish mounts a female and inserts the flexible genital papilla, functioning as a penis, into the genital pore of the female. The combination of copulation and paternal egg-care was first observed in Artedius harringtoni by Ragland and Fischer. If spermatozoa can retain fertility in ovarian cavities, copulation can increase reproductive success of males by increasing access of sperm to eggs throughout several clutches. The diverse anatomy such as external genital papillae was once considered to be a decisive factor of copulation, but hemitripterid species exhibit copulation without protrusive papilla. Copulation permits the temporal and spatial separation of mating and spawning and allows females to delay egg deposition until encountering favorable environmental conditions.},
	journal = {Reproductive Biology and Phylogeny of Fishes, Vol 8B: Part B: Sperm Competion Hormones},
	author = {Abe, Takuzo and Munehara, Hiroyuki},
	year = {2009},
	note = {Num Pages: 26},
	pages = {221--246},
}

@article{allen_seasonal_1982,
	title = {Seasonal abundance, composition, and productivity of the littoral fish assemblages in {Upper} {Newport} {Bay}, {California}},
	volume = {80},
	url = {https://books.google.ca/books?hl=en&lr=&id=V90opjXSBycC&oi=fnd&pg=PA769&dq=Atherinops+affinis+juvenile+migration&ots=mB3_b9GhLN&sig=Iy2-MsyObovFjUcV1kjQr2tEc-Y#v=onepage&q=Atherinops%20affinis%20juvenile%20migration&f=false},
	abstract = {This study was designed to characterize the littoral fish populations by 1 ) composition and principal species, 2) diversity and seasonal dynamics, 3) productivity, and 4) important environmental factors. Monthly samples (January 1978 to January 1979) obtained with four quantitative sampling methods at three stations in upper Newport Bay yielded 55,561 fishes from 32 species which weighed 103.5 kg. The top five species made up over 98\% of the total number of individuals. One species, Atherinops affinis, predominated in numbers (76.7\% of all fishes) and biomass (79.8\% ). This dominance was reflected in the low overall H' diversity values for numbers (H' = 0.89) and biomass (HB = 0.84). Number of species, number of individuals , and biomass were greatest during the spring and summer.},
	language = {en},
	number = {4},
	journal = {Fishery Bulletin},
	author = {Allen, Larry G.},
	year = {1982},
	note = {Number: 4},
	pages = {769--790},
}

