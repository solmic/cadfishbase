	volume = {54},
	issn = {1469-7769, 0025-3154},
	url = {https://www.cambridge.org/core/journals/journal-of-the-marine-biological-association-of-the-united-kingdom/article/vertical-distribution-of-cephalopods-at-30n-23w-in-the-north-atlantic/87B46DB72264E8DFD73C3F8CAC93A299},
