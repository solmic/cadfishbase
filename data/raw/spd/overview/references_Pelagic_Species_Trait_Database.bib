	volume = {112},
	url = {https://www.researchgate.net/profile/Michael_Vecchione/publication/268435263_Morphological_Observations_On_A_Hatchling_And_A_Paralarva_Of_The_Vampire_Squid_Vampyroteuthis_Infernalis_Chun_Mollusca_Cephalopoda/links/55b7adb808aed621de04792a.pdf},
