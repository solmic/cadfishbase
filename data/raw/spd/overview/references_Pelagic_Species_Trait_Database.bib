	pages = {1646--1649},
}

@article{oliveira_chemical_2014,
	title = {Chemical {Composition} of {Spiny} {Dogfish} (\textit{{Squalus} suckleyi}) {Harvested} in {Alaska}: {Spiny} {Dogfish} {Composition}},
	volume = {38},
	issn = {01458892},
	shorttitle = {Chemical {Composition} of {Spiny} {Dogfish} ( \textit{{Squalus} suckleyi} ) {Harvested} in {Alaska}},
	url = {https://onlinelibrary.wiley.com/doi/10.1111/jfpp.12008},
	doi = {10.1111/jfpp.12008},
	abstract = {Spiny dogﬁsh is an underutilized yet abundant species harvested as bycatch in Alaska. The research goal was to determine the nutritional composition of dogﬁsh by-products and compare results with headed and gutted (H\&G) dogﬁsh. Large differences existed in lipid content between the heads (1.8\% w/w), H\&G (9.2\% w/w) and livers (65.4\% w/w). The overall omega-3 fatty acid content ranged from 75.7 to 162 mg/g lipids in all tissues. Cholesterol content was signiﬁcantly higher in livers (602 mg/100 g tissue) than in heads or H\&G. Values for three potentially limiting amino acids ranged in the tissues from 2.6 to 2.8\% w/w for methionine, 4.2 to 5.2\% w/w for threonine and 6.9 to 8.8\% w/w for lysine. Dogﬁsh livers are a good source of ﬁsh oil, while heads and H\&G are rich in protein and low in ash, which make these two products ideal raw materials for production of ﬁsh hydrolysates.},
	language = {en},
	number = {1},
	urldate = {2023-05-08},
	journal = {Journal of Food Processing and Preservation},
	author = {Oliveira, Alexandra C.M. and Bechtel, Peter J. and Morey, Amit and Brenner, Kathryn and Lapis, Trina J.},
	month = feb,
	year = {2014},
	note = {Number: 1},
	pages = {600--606},
}

