@article{mallol_abundance_2014,
	title = {Abundance and {Distribution} of {Scyllarid} {Phyllosoma} {Larvae} ({Decapoda}: {Scyllaridae}) in the {Balearic} {Sea} ({Western} {Mediterranean})},
	volume = {34},
	issn = {0278-0372},
	shorttitle = {Abundance and {Distribution} of {Scyllarid} {Phyllosoma} {Larvae} ({Decapoda}},
	url = {https://doi.org/10.1163/1937240X-00002250},
	doi = {10.1163/1937240X-00002250},
	abstract = {The distribution, abundance, and interannual variation of scyllarid phyllosoma larvae were studied in waters of the Balearic Sea (Western Mediterranean) from plankton samples collected between 2001 and 2005. Over the study period, 342 phyllosomas were collected, all belonging to Scyllaridae. Scyllarus arctus (Linnaeus, 1758) was the most abundant (89\%), with representation of all developmental stages (I-X), except stage IX, plus two nistos. Scyllarus pygmaeus (Bate, 1888) phyllosoma included middle stages (IV-VII) and two final stages X. Finally, a stage II phyllosoma of Scyllarides latus (Latreille, 1802) was recorded for the first time in the Western Mediterranean. The majority of the phyllosomas were early stage S. arctus found in near shore stations, while advanced stages were common farther away from the coast, especially to the south of the Balearic Sea. That was also the case of S. pygmaeus, most of which stage V, observed to the southwest of the archipelago. Phyllosomas were scarce in low salinity \$(S {\textbackslash}lt 37.2)\$ water masses of recent Atlantic origin, and interannual differences in distribution reflected the intrusions of low salinity Atlantic water from the South.},
	number = {4},
	urldate = {2023-08-02},
	journal = {Journal of Crustacean Biology},
	author = {Mallol, Sandra and Mateo-Ramírez, Ángel and Alemany, Francisco and Álvarez-Berastegui, Diego and Díaz, David and López-Jurado, José Luis and Goñi, Raquel},
	month = jul,
	year = {2014},
	note = {Number: 4},
	pages = {442--452},
}

