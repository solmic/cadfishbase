@article{hanel_larval_2010,
	title = {Larval fish abundance, composition and distribution at {Senghor} {Seamount} ({Cape} {Verde} {Islands})},
	volume = {32},
	issn = {0142-7873},
	url = {https://doi.org/10.1093/plankt/fbq076},
	doi = {10.1093/plankt/fbq076},
	abstract = {The Cape Verdean Senghor-Seamount rises up to 93 m below the surface, and lies within the Cape Verde Frontal Zone (CVFZ), and within the southwestward North Equatorial Current. The seamount and its oceanic surroundings were surveyed with Multiple-Opening-Closing Net (MCN) fish larval catches, Issacs-Kidd midwater trawl (IKMT) micronekton hauls and an analysis of some conductivity–temperature–depth data (RV Poseidon cruise no. POS 320/2). The thermal and saline stratifications showed widely symmetrical uplifts near the summit. The larval fish community was diverse (H′ = 2.656) and composed mainly of larvae of meso- to bathypelagic species (91.5\%). In IKMT, 44.1\% of the specimens originated from demersal parents (H′ = 3.296), and mostly, albeit not entirely, from West African coastal waters, after advection along the CVFZ to and across this potential “stepping stone”. Gross larval fish abundance (median 35.5 specimens/1 m2) and composition agreed well with historical literature data from adjacent waters and seamounts north of the CVFZ, whereas south of the CVFZ and towards NW-Africa reported abundances were higher. Vertical distributions of larvae which generally live at greater depths showed a rise above the seamount, following the hydrographic uplift, accompanied by “thinning-out effects” through bathymetric disturbance. The extent to which findings at Senghor Seamount are representative for small, shallow and steep seamounts in the tropical NE-Atlantic is discussed.},
	number = {11},
	urldate = {2023-08-21},
	journal = {Journal of Plankton Research},
	author = {Hanel, Reinhold and John, Hans-Christian and Meyer-Klaeden, Ole and Piatkowski, Uwe},
	month = nov,
	year = {2010},
	note = {Number: 11},
	pages = {1541--1556},
}

@article{zidowitz_life_2004,
	title = {Life cycle of \textit{{Antigonia} capros} {Lowe}, 1843 at the {Great} {Meteor} {Seamount} (subtropical {North}-east {Atlantic})},
	volume = {51},
	url = {https://www.researchgate.net/profile/Heike_Zidowitz/publication/251571256_Life_cycle_of_Antigonia_capros_Lowe_1843_at_the_Great_Meteor_Seamount_subtropical_North-east_Atlantic/links/53e491a60cf2fb748710d3df/Life-cycle-of-Antigonia-capros-Lowe-1843-at-the-Great-Meteor-Seamount-subtropical-North-east-Atlantic.pdf},
	abstract = {Although the boarfish Antigonia capros is a common representative on seamounts and the continental shelf, knowledge of its population structure and life history is very scarce. Data from the Great Meteor Seamount (GMR) in the subtropical NE Atlantic for 1998 are presented and discussed in view of results obtained during cruises in 1967 and 1970 by other scientists. Morphometric data were taken for 39 specimens of A. capros including estimates of the state of maturity for females. The mean length of 74 specimens was 20.3 cm with a range from 12 cm to 23 cm in total length (TL). Spawning probably occurs at the GMR in September/October, since there are reports of larvae caught above the seamount plateau during these months. Successful recruitment is suggested to be irregular and probably occurs at time intervals when environmental conditions are favourable. This hypothesis is also supported by the population structure, which, at the time of investigation (September 1998), lacked the very small size classes, although juveniles of the year had been caught during the study.},
	journal = {Archive of Fishery and Marine Research},
	author = {Zidowitz, Heike and von Westernhagen, Hein},
	month = jan,
	year = {2004},
	pages = {272--286},
}

@article{hastie_chapter_2013,
	title = {Chapter {IV} - \textit{{Alloteuthis} subulata}, {European} {Common} {Squid}},
	url = {https://www.researchgate.net/profile/Louis-Zeidberg/publication/264543631_Advances_in_Squid_Biology_Ecology_and_Fisheries_Part_I_-_Myopsid_Squids/links/5435686f0cf2dc341db21d72/Advances-in-Squid-Biology-Ecology-and-Fisheries-Part-I-Myopsid-Squids.pdf#page=125},
	abstract = {The squid Alloteuthis subulata (Cephalopoda: Loliginidae) is a small species, widely distributed in shallow coastal waters of the north-eastern Atlantic and adjacent waters. It is commercially exploited in some areas, principally as by-catch, but it is not considered to be economically important at present, and very little is known about its ecology. Nevertheless, it is considered to be an important species since it appears to be an abundant predator of small fish and is itself preyed upon by a number of larger marine animals. This review provides current knowledge on the zoogeography, biology and ecology of A. subulata across its north-eastern Atlantic range.},
	language = {en},
	journal = {Advances in Squid Biology, Ecology and Fisheries. Part I - Myopsid Squids},
	author = {Hastie, Lee C. and Allcock, A. Louise and Jereb, Patrizia and Lefkaditou, Eugenia and Moreno, Ana and Oesterwind, Daniel and Pierce, Graham J.},
	year = {2013},
	pages = {109--122},
}

@article{heffernan_vertical_1981,
	title = {Vertical {Distribution} and {Feeding} of the {Shrimp} {Genera} \textit{{Gennadas}} and \textit{{Bentheogennema}} ({Decapoda}: {Penaeidea}) in the {Eastern} {Gulf} of {Mexico}},
	volume = {1},
	issn = {0278-0372},
	shorttitle = {Vertical {Distribution} and {Feeding} of the {Shrimp} {Genera} {Gennadas} and {Bentheogennema} ({Decapoda}},
	url = {https://www.jstor.org/stable/1548124},
	doi = {10.2307/1548124},
	abstract = {Five species of Gennadas and one species of the closely related genus Bentheogennema are found in the eastern Gulf of Mexico. Gennadas undergoes diel migration with most of the population concentrating at 650-850 m in the day and at 150-400 m during the night. Bentheogennema intermedia remains below 900 m. Gennadas valens is the most abundant species and constitutes 63\% of the Gennadas catch. Maximum density for the genus was 6/1,000 m$^{\textrm{3}}$ and the number under a square meter of sea surface was estimated at 2 individuals. Populations have been underestimated, however, as juveniles escape through the trawl meshes. The diets of Gennadas and Bentheogennema are diverse and consist of a wide variety of primarily small, 1-5 mm plankton (mostly copepods) and greenish brown detritus containing fragments of epipelagic microplankton. Little difference exists in the diets of the six species considered, or between adults and juveniles of the most abundant species, G. valens. The appendages of these penaeids appear to be structurally adapted for capturing both the prey and detritus found in their digestive tracts. Evidence exists for time-space resource partitioning if the entire diel period and population size structure are considered. However, there is marked co-occurrence of triplets and pairs of species at night, the period of most active feeding.},
	number = {4},
	urldate = {2023-08-21},
	journal = {Journal of Crustacean Biology},
	author = {Heffernan, John J. and Hopkins, Thomas L.},
	year = {1981},
	note = {Number: 4
Publisher: [Brill, Crustacean Society]},
	pages = {461--473},
}

