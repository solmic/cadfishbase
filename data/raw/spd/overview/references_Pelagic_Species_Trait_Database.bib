@article{carpentieri_food_2016,
	title = {Food preferences and rhythms of feeding activity of two co-existing demersal fish, the longspine snipefish, \textit{{Macroramphosus} scolopax} ({Linnaeus}, 1758), and the boarfish \textit{{Capros} aper} ({Linnaeus}, 1758), on the {Mediterranean} deep shelf},
	volume = {37},
	issn = {1439-0485},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/maec.12265},
	doi = {10.1111/maec.12265},
	abstract = {The feeding behaviour of two potentially competing species, the longspine snipefish, Macroramphosus scolopax, and the boarfish Capros aper was examined. While both species are very abundant along the Mediterranean coast and are regularly caught by demersal trawlers, they are of no commercial value. The diets of boarfish and longspine snipefish were investigated from samples collected between January 2001 and May 2002. Variations in the diet with fish size and season, as well as diet overlap and diversity were explored. Mysid shrimps, amphipods and gastropods were the most important food items in the diet of longspine snipefish. During ontogenetic development, M. scolopax occupies different trophic levels: the diet shifts from being predominantly composed of mysids (Anchialina agilis, Lophogaster typicus, Erythrops sp., Leptomysis spp.) in the smaller longspine snipefish [{\textless}6.5 cm total length (TL)] towards decapods (Anapagurus laevis) and amphipods (Leucothoe incisa, Eusirus longipes, Hyperidea) in the larger individuals ({\textgreater}6.5 cm TL). Crustacean decapods and copepods were the most important prey in the stomachs of boarfish. Mysids (Lo. typicus), euphausiids and nematodes were present in the larger individuals ({\textgreater}8 cm TL). A more generalist diet, still containing copepods, crustacean decapods, gastropods (Limacina retroversa) and a large variety of amphipods (e.g. Phtysica marina, Stenotoe bosphorana) and mysids (e.g. A. agilis, Leptomysis spp., Erythrops sp.), dominated the diet of C. aper between 2 and 8 cm TL. Diet overlap between longspine snipefish and boarfish was very low and the differences in stomach species diversity were explained by season and fish size.},
	language = {en},
	number = {1},
	urldate = {2023-08-17},
	journal = {Marine Ecology},
	author = {Carpentieri, Paolo and Serpetti, Natalia and Colloca, Francesco and Criscoli, Alessandro and Ardizzone, Giandomenico},
	year = {2016},
	note = {Number: 1
\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/maec.12265},
	keywords = {Mediterranean Sea, Boarfish, feeding, longspine snipefish},
	pages = {106--118},
}

