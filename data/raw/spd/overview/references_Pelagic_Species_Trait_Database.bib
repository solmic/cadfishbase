@article{falardeau_first_2017,
	title = {First records of {Pacific} sand lance (\textit{{Ammodytes} hexapterus}) in the {Canadian} {Arctic} {Archipelago}},
	volume = {40},
	issn = {1432-2056},
	url = {https://doi.org/10.1007/s00300-017-2141-0},
	doi = {10.1007/s00300-017-2141-0},
	abstract = {An increasing number of boreal marine species are expected to invade the warming Arctic Ocean with the potential to displace endemic species. We provide first evidence that Pacific sand lance (Ammodytes hexapterus) is expanding its range in the Canadian Arctic Archipelago, a region far outside the species temperate-boreal traditional range south of the Bering Strait. To the best of our knowledge, supported by local Inuit knowledge, the species was not present in the area until the present decade. We observed an increasing density of larval Pacific sand lance with time over the 2011–2016 period, suggesting that environmental conditions are becoming increasingly favorable for the species to reproduce in the Central Canadian Arctic. The northward distribution change of Pacific sand lance is occurring earlier than predicted by current models and could trigger abrupt shifts in Arctic marine food webs if the boreal invader displaces polar cod, a key prey species for top predators in Arctic marine ecosystems.},
	language = {en},
	number = {11},
	urldate = {2023-07-11},
	journal = {Polar Biology},
	author = {Falardeau, Marianne and Bouchard, Caroline and Robert, Dominique and Fortier, Louis},
	month = nov,
	year = {2017},
	note = {Number: 11},
	keywords = {Climate change, Climate-related invasion, Fish communities, Northwest Passage, Range shift, Sandeel},
	pages = {2291--2296},
}

@article{robards_changes_1999-1,
	title = {Changes in proximate composition and somatic energy content for {Pacific} sand lance (\textit{{Ammodytes} hexapterus}) from {Kachemak} {Bay}, {Alaska} relative to maturity and season},
	volume = {242},
	issn = {00220981},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S0022098199001021},
	doi = {10.1016/S0022-0981(99)00102-1},
	abstract = {Mean dry-weight energy values of adult Paciﬁc sand lance (Ammodytes hexapterus) peaked in spring and early summer (20.91 kJg21 for males, 21.08 kJg21 for females), then declined by about 25\% during late summer and fall (15.91 kJg21 for males, 15.74 kJg21 for females). Late summer declines in energy density paralleled gonadal development. Gender differences in energy density (males , females) were only apparent from August to October. Adult sand lance spawn in October, entering the winter with close to their minimum whole body energy content. Juvenile sand lance exhibited a relatively constant protein to lipid ratio until they reached 80 mm fork length. Thereafter, relative proportions of protein remained constant while lipid proportions increased signiﬁcantly. Dry weight energy densities of juveniles increased from a minimum 16.67 kJg21 to a maximum of 19.68 kJg21, and (per g) are higher than adults in late summer. The seasonal food value of adult sand lance to predators varies markedly, but maximum energetic value coincides with important feeding periods for marine mammals, ﬁsh, and seabirds. Published by Elsevier Science B.V.},
	language = {en},
	number = {2},
	urldate = {2023-07-11},
	journal = {Journal of Experimental Marine Biology and Ecology},
	author = {Robards, Martin D and Anthony, Jill A and Rose, George A and Piatt, John F},
	month = oct,
	year = {1999},
	note = {Number: 2},
	pages = {245--258},
}

@article{wright_influence_2000,
