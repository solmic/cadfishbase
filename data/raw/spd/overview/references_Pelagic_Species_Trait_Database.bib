@article{kurogi_adult_2016,
	title = {Adult form of a giant anguilliform leptocephalus \textit{{Thalassenchelys} coheni} {Castle} and {Raju} 1975 is \textit{{Congriscus} megastomus} ({Günther} 1877)},
	volume = {63},
