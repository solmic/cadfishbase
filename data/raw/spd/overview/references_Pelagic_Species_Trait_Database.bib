@article{mcfarlane_effect_1990,
	title = {Effect of an {External} {Tag} on {Growth} of {Sablefish} (\textit{{Anoplopoma} fimbria}), and {Consequences} to {Mortality} and {Age} at {Maturity}},
	volume = {47},
	issn = {0706-652X, 1205-7533},
	url = {http://www.nrcresearchpress.com/doi/10.1139/f90-175},
	doi = {10.1139/f90-175},
	abstract = {Tagged juveniles from a strong year-class of sablefish (Anoplopoma fimbria) were sampled for 9 yr Tagged females were approximately 6 cm larger than untagged females at 50\% maturity. Males showed little difference because of their slower growth rate. Untagged males and females matured one and 2 yr earlier than tagged males and females. From this same year-class length-at-age of untagged males and females was significantly larger than for tagged and recaptured fish. Untagged males and females were 6.5 and 8 cm larger than tagged fish by age seven. Smaller tagged fish were recaptured at lower rates than larger tagged fish, indicating that slower growth reduced recapture percentage, which we believe indicates a higher mortality rate. Because smaller size was associated with increased mortality and tagged fish grew slower than untagged fish, we concluded that tagged fish had higher rates of mortality than untagged fish. The increased age and size at 50\% maturity and the increased juvenile mortality indicated the potential response of a population of sablefish and possibly other species to a reduction in individual fish growth. If our results apply to other species and other types of tags, investigators should be cautious in extrapolating from tagged to untagged populations.},
	language = {en},
	number = {8},
	urldate = {2023-08-24},
	journal = {Canadian Journal of Fisheries and Aquatic Sciences},
	author = {McFarlane, Gordon A. and Beamish, Richard J.},
	month = aug,
	year = {1990},
	note = {Number: 8},
	pages = {1551--1557},
}

@article{jasonowicz_love_2017,
	title = {Love the one you’re with: genomic evidence of panmixia in the sablefish (\textit{{Anoplopoma} fimbria})},
	volume = {74},
	issn = {0706-652X},
	shorttitle = {Love the one you’re with},
	url = {https://cdnsciencepub.com/doi/10.1139/cjfas-2016-0012},
	doi = {10.1139/cjfas-2016-0012},
	abstract = {Understanding the genetic structure of a fishery may help delineate stocks and is directly applicable to resource management. To date, studies have not found clear population genetic structure across the range of the sablefish (Anoplopoma fimbria), yet significant biological differences are recognized. Here we use restriction site-associated DNA sequencing to develop thousands of single nucleotide polymorphisms (SNPs) throughout the sablefish genome and assess population genetic structure and examine the genome for SNPs under natural selection. Our study was unable to target spawning groups, having the potential to bias analyses that require a priori hypotheses of population structure. Low and insignificant levels of differentiation (FST = 0.0002) were observed among survey areas, and analyses of population structure suggested a single population. Only two SNPs were significantly associated with environmental variables. These results are likely due to considerable population mixing and suggest a single panmictic group of sablefish off the west coast of the United States and Alaska that is likely a consequence of a complex juvenile life history and long range movements as adults.},
	number = {3},
	urldate = {2023-08-24},
	journal = {Canadian Journal of Fisheries and Aquatic Sciences},
	author = {Jasonowicz, Andrew J. and Goetz, Frederick W. and Goetz, Giles W. and Nichols, Krista M.},
	month = mar,
	year = {2017},
	note = {Number: 3
Publisher: NRC Research Press},
	pages = {377--387},
}

@article{shenker_laboratory_1986,
	title = {Laboratory {Feeding} and {Growth}.of {Juvenile} {Sablefish}, \textit{{Anoplopoma} fimbria}},
	volume = {43},
	issn = {0706-652X, 1205-7533},
	url = {http://www.nrcresearchpress.com/doi/10.1139/f86-115},
	doi = {10.1139/f86-115},
	abstract = {We collected wild juvenile sablefish (Anoplopoma fimbria) from the neuston off Oregon and established them in laboratory culture. Growth was determined weekly for up to 8 wk for fish over a size range of 35–110 mm SL (0.3–16.5 g) when provided with one of two live prey species at four ration levels. Fish were fed either mysid shrimp, Archaeomysis grebnitzkii, or adult brine shrimp, Artemia salina, at ration sizes of 10, 20, and 30\% wet body weight/d, and with ad libitum availability of food. Fish provided with mysids at a given ration size generally had mean daily length and weight increments higher than those achieved with Artemia at the same ration. Superiority of the mysids for promoting growth was primarily due to their higher dry to wet weight ratio. Gross conversion efficiencies exceeding 40\% were achieved on low rations of mysid prey. Peak growth exceeding 2 mm/d and 1.0 g/d establishes juvenile neustonic sablefish among the fastest growing juvenile fishes yet examined.},
	language = {en},
	number = {5},
	urldate = {2023-08-24},
	journal = {Canadian Journal of Fisheries and Aquatic Sciences},
	author = {Shenker, Jonathan M. and Olla, Bori L.},
	month = may,
	year = {1986},
	note = {Number: 5},
	pages = {930--937},
}

