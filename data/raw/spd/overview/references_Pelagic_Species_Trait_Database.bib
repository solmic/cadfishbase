@article{schwartz_searobins_2005,
	title = {Searobins (family {Triglidae}) and {Armoured} {Searobins} (family {Peristediidae}) (scorpaeniformes) in {North} {Carolina} and {Adjacent} {Areas}: {Distributions}, {Abundances} and {Sizes}},
	volume = {121},
	issn = {2167-5872},
	shorttitle = {Searobins (family {Triglidae}) and {Armoured} {Searobins} (family {Peristediidae}) (scorpaeniformes) in {North} {Carolina} and {Adjacent} {Areas}},
	url = {https://www.jstor.org/stable/24336052},
	abstract = {Distributions, sizes and length relationships are documented for three species of Bellator and nine species of Prionotus searobins (family Triglidae) and six species of Peristedion, armoured searobins (family Peristediidae) captured in inshore and/or offshore waters of North Carolina and adjacent areas. Prionotus carolinus is the most common, Prionotus tribulus the most adundant searobin throughout the state. Cape Fear river serves as a nursery area for five species of Prionotus. Collected Triglids and Peristiids are smaller, weigh less and frequent shallower waters than known. Four species: Bellator miniatum, Prionotus evolans, Prionotus rubio and Peristedion miniatum total lengths are longer than known. Four species: P. evolans, P. rubio, P. scitulus, and P. tribulus often occur in inside waters; all other species are offshore inhabitants. Lack of recent Bellator or Peristedion captures is linked to reduced offshore sampling. A changing and warm ocean may also explain recent abundances of Triglids and Peristiids in North Carolina and adjacent areas.},
	number = {4},
	urldate = {2023-08-28},
	journal = {Journal of the North Carolina Academy of Science},
	author = {Schwartz, Frank J.},
	year = {2005},
	note = {Number: 4
Publisher: Temporary Publisher},
	pages = {157--169},
}

