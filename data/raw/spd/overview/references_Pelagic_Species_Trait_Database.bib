@article{badcock_remarks_1980,
	title = {Remarks on systematics, development, and distribution of the hatchetfish genus \textit{{Sternoptyx}} ({Pisces}, {Stomiatoidei})},
	volume = {77},
	url = {https://books.googleusercontent.com/books/content?req=AKW5QafAr_JX0BEOnGAa2J2gJngCxh-FW3V4oi6-Rggm912Fx5SLGIi2NUDljUrjhzb1CWY6EU2bYDbP0uozIMLNlh5199qFqK5vRpRQOatot6VJCl6TntNEfnYn4VpOmVSTuTfg7IvpYORgxYzL8XD4CcvZUkUtK8BYCJqLCbFmAtgUQFipeSbGa__zDuxpA9T7NVN-oCiZ_lO__6pb6AZ94KADl1HUwscrwlIBp-fJ_YJ2d6kcYoNqaqDDRst929rSC92WsWjd},
	abstract = {Sternoptyx pseudodiaphana Borodulina is reported from the eastern North Atlantic in sympatry with S. diaphana, providing conclusive evidence that the former represents a species distinct from S. diaphana. Patterns of geographic variation among various characters are apparent in species of Sternoptyx as is allometric growth. These patterns render species identification difficult in certain allopatric populations, particularly those from the Atlantic and Pacific Oceans. Each species has distinct patterns of horizontal and vertical distribution and where species occur in sympatry, their centers of abundance do not coincide. Members ofthe genus Sternoptyx inhabit the "lower mesopelagic depth zone" (sensu Baird) from 500 to 1,500 m. Geographic variation in depth of maximum abundance for various species can be demonstrated. These appear correlated with variations in temperature and light although competitive interactions may also contribute to observed depth ranges. Photophore development is similar in the three species described and postlarval individuals of S. diaphana and S. pseudodiaphana are readily distinguishable. Characters useful in distinguishing the various species are presented in relation to patterns of geographic variation.},
	language = {en},
	number = {4},
	journal = {Fishery Bulletin},
	author = {Badcock, Julian and Baird, Ronald C.},
	year = {1980},
	note = {Number: 4},
	pages = {803--820},
}

@article{castro_occurrence_2010,
	title = {Occurrence and distribution of larval lanternfish ({Myctophidae}) from the southwest {Atlantic} {Ocean}},
	volume = {27},
	issn = {1984-4689},
	url = {http://www.scielo.br/scielo.php?script=sci_arttext&pid=S1984-46702010000400006&lng=en&nrm=iso&tlng=en},
	doi = {10.1590/S1984-46702010000400006},
	abstract = {This study analyzes the occurrence and distribution of lanternfish (Myctophidae) larvae along the Brazilian coast (12-22°S) between 200 m and the surface. Three cruises were conducted during the spring/1998, winter/1999 and autumn/2000. A total of 3,394 lanternfish larvae were identified representing 27 species and Lepidophanes guentheri (Goode \& Bean, 1896) was the most abundant. Most of the identified taxa were in the postflexion stage. Myctophid larvae were more numerous during the winter. Most taxa were distributed widely from 12-22°S, including some seamounts, and occurred mainly outside the 1,000 m isobath. Although there was no difference in the myctophid community among the coastal, oceanic and seamount regions it was significantly different during the three seasons. During the spring and autumn Hygophum reinhardtii (Lütken, 1892) was the discriminating species while in the winter there were more L. guentheri. KEY WORDS. Brazilian coast; larval mesopelagic fish; Myctophidae; spatial variation; tropical region.},
	language = {en},
	number = {4},
	urldate = {2023-08-11},
	journal = {Zoologia (Curitiba)},
	author = {Castro, Márcia S. De and Richards, William J. and Bonecker, Ana Cristina T.},
	month = aug,
	year = {2010},
	note = {Number: 4},
	pages = {541--553},
}

@article{demicheli_mass_2006,
