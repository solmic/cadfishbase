@article{skrivanic_migrations_1973,
	title = {Migrations of the sardine (\textit{{Sardina} pilchardus}) in relation to hydrographical conditions of the {Adriatic} sea},
	volume = {7},
	issn = {0077-7579},
	url = {https://www.sciencedirect.com/science/article/pii/0077757973900288},
	doi = {10.1016/0077-7579(73)90028-8},
	abstract = {In the Adriatic Sea, the sardine (Sardina pilchardus Walb.) is economically the most important pelagic fish species. It spawns from autumn until spring in the areas which are strongly defined with regard to some hydrographical factors, such as temperature, salinity, current system, depth and others. These spawning grounds are located in the areas with optimal biological conditions, where the hydrographical equilibrium is established between two types of sea water: the “Mediterranean” one, and the “Alpic” one which is formed in the shallow northern part of the Adriatic sea by dominated influence of north Italian rivers. After spawning, in search for food, the fish migrate to high productive shallow regions where in the summer the sardine is intensively fished. Due to topographical characters and hydrographical polarisation of the Adriatic sea, the subpopulations of the sardine differ generally with regard to their directions, distances and time of their migrations. But there are indications that due to environmental conditions limited mixing of sardine stocks inhabiting various regions of the Adriatic Sea is possible.},
	urldate = {2023-08-15},
	journal = {Netherlands Journal of Sea Research},
	author = {Škrivanić, A. and Zavodnik, D.},
	month = aug,
	year = {1973},
	pages = {7--18},
}

@article{tsangridis_exploitation_2002,
	title = {Exploitation patterns of \textit{{Octopus} vulgaris} in two {Mediterranean} areas},
	volume = {66},
	issn = {1886-8134, 0214-8358},
	url = {http://scientiamarina.revistas.csic.es/index.php/scientiamarina/article/view/564/577},
	doi = {10.3989/scimar.2002.66n159},
	abstract = {Exploitation patterns of the common octopus, Octopus vulgaris, in two Mediterranean areas were studied in three ports, two in the Thracian Sea (Greece, Eastern Mediterranean) and one in the Catalan Sea (Spain, Western Mediterranean). The study period of one year (July 1998-June 1999) included a monthly collection of data on commercial landings, fishing effort and length distribution of O. vulgaris. Many gears exploit this species in both areas. Specialised and highly productive artisanal gears (fyke nets, pots and traps) have been developed. Herein it is shown that: (1) trawls are responsible for most octopus landings; (2) trawls exploit mostly the small and immature individuals while the artisanal fleets exploit the large and mature ones; (3) there is a marked seasonality of catches; (4) there is little or no interaction between the gears fishing octopus, indicating that each gear affects a certain size range; (5) and the octopus specimens from the Greek area are clearly smaller than the ones from the Spanish area. Our results suggest that octopus fisheries require more effective management strategies. The creation of marine harvest refuges may be beneficial.},
	language = {en},
	number = {1},
	urldate = {2023-08-10},
	journal = {Scientia Marina},
	author = {Tsangridis, Alexis and Sánchez, Pilar and Ioannidou, Despina},
	month = mar,
	year = {2002},
	note = {Number: 1},
	pages = {59--68},
}

