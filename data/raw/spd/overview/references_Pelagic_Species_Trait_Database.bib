	url = {https://linkinghub.elsevier.com/retrieve/pii/0022098183901107},
	doi = {10.1016/0022-0981(83)90110-7},
	abstract = {The biochemical composition of three species of North Sea ctenophores, the beroid Beroe gracilis (Kiinne), the tentaculate Pleurobrachiapileus (Fabricius) and the lobate Bolinopsis infundibulum (Mtiller), was analysed in terms of total fractions of protein, lipid, ninhydrin-positive substances (NPS), polysaccharides (PS), and low molecular-weight carbohydrates (LMC). The sum of these biochemical fractions was highest in Beroe (128 mg/g dry wt) and much lower in Pleurobrachia (61 mg/g dry wt) and Bolinopsis (27 mg/g dry wt). Beroe shows higher ratios of NPS/protein and LMCjPS than either of the other species. These findings are explained by differences in the morphology and metabolism of the species.},
