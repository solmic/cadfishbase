@article{herring_depth_1973,
	title = {Depth {Distribution} of the carotenoid pigments and lipids of some oceanic animals. 2. {Decapod} {Crustaceans}},
	volume = {53},
	issn = {0025-3154, 1469-7769},
	url = {https://www.cambridge.org/core/product/identifier/S0025315400058756/type/journal_article},
	doi = {10.1017/S0025315400058756},
	abstract = {Analysis of the carotenoid pigments of decapod crustaceans has indicated that the visible differences in the appearance of species from different depth horizons are largely due to the disposition of pigments and not to differences in total amount of pigment relative to body size. Species from the upper mesopelagic zone have relatively few large chromatophores, and their chitin is either unpigmented or feebly pigmented. Species from deeper zones have very many small chromatophores and chitin heavily pigmented by unesterified astaxanthin. The major carotenoid pigments of almost all species are astaxanthin and its esters.},
