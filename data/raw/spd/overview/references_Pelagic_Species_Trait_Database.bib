@article{brinton_two_1962,
	title = {Two {New} {Species} of {Euphausiacea}, \textit{{Euphausia} nana} and \textit{{Stylocheiron} robustum} from the {Pacific}},
	volume = {4},
	issn = {0011-216X},
	url = {https://www.jstor.org/stable/20102480},
	abstract = {Zwei neue Arten von Euphausiiden sind in Planktonproben vom Stillen Ozean gefunden worden. Euphausia nana sp. nov. unterscheidet sich von der verwandten Art Euphausia pacifica Hansen in Struktureinzelheiten der terminalen und proximalen Fortsätze der Copulations-organe des Männchens. E. nana ist sehr viel kleiner als E. pacifica. Euphausia nana ist in der Ost-Chinesischen See sowie im Gebiet südöstlich von Japan gefunden worden, und lebt möglicherweise geographisch isoliert von der nördlicheren E. pacifica. Die "dominierende Stadien" der Larven sind nahezu identisch in beiden Arten. Sie sind aber kleiner bei E. nana als bei E. pacifica. Stylocheiron robustum sp. nov., eine dritte Art der "Stylocheiron maximum Gruppe", bewohnt die warmen Gewässer des zentralen und westtropischen Stillen Ozeans, und wurde auch von Süd-Afrika gemeldet.},
