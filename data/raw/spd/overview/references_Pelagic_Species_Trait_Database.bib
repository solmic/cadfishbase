@article{guerao_morphology_2006,
	title = {Morphology of {Puerulus} and {Early} {Juvenile} {Stages} of the {Spiny} {Lobster} \textit{{Palinurus} mauritanicus} ({Decapoda}: {Palinuridae})},
	volume = {26},
	issn = {0278-0372},
	shorttitle = {Morphology of {Puerulus} and {Early} {Juvenile} {Stages} of the {Spiny} {Lobster} {Palinurus} {Mauritanicus} ({Decapoda}},
	url = {https://doi.org/10.1651/C-2615.1},
	doi = {10.1651/C-2615.1},
	abstract = {Puerulus and early juvenile stages of the spiny lobster Palinurus mauritanicus Gruvel, 1911 from the western Mediterranean are described and illustrated, and their morphological characteristics are compared with those described in other palinurids. This constitutes the first detailed morphological description of a puerulus of the genus Palinurus. The puerulus of P. mauritanicus presents a carapace already with some spines characteristic of the adult phase, which allows to differentiate it from the congeneric species Palinurus elephas (Fabricius, 1787) co-occurring in most of its distribution area. The puerulus of P. mauritanicus can be differentiated from those described for pueruli of the genera Panulirus and Jasus by the presence of very long, flagellated, and setose exopods on maxillipeds 2 and 3. The puerulus of P. mauritanicus resembles those described for Projasus by the presence of the crista dentata on the third maxilliped. The morphology and differential colouration of the early juvenile with respect to the adult are described.},
	number = {4},
	urldate = {2023-08-16},
	journal = {Journal of Crustacean Biology},
	author = {Guerao, Guillermo and Díaz, David and Abelló, Pere},
	month = oct,
	year = {2006},
	note = {Number: 4},
	pages = {480--494},
}

