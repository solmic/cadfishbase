@article{mason_biology_1985,
	title = {Biology of the {Bathylagid} {Fish}, \textit{{Leuroglossus} schmidti} , in the {Strait} of {Georgia}, {British} {Columbia}, {Canada}},
	volume = {42},
	issn = {0706-652X, 1205-7533},
	url = {http://www.nrcresearchpress.com/doi/10.1139/f85-141},
	doi = {10.1139/f85-141},
	abstract = {The northern smoothtongue (Leuroglossus schmidti), a deep-sea smelt, coexists with Pacific hake (Merluccius productus) and walleye pollock (Theragra chalcogramma) in the Strait of Georgia, British Columbia. Their eggs and larvae rank third in abundance, and these three pelagic stocks show marked spatial and temporal overlap in deeper waters, especially during reproduction. Development to hatching occurs in the spring at depths {\textgreater} 150 m. Smelt larvae metamorphose at 22 mm standard length (SL), some 90 d from hatching, and juveniles join the adults at depths {\textgreater} 200 m by autumn. Larger juveniles mature as 2-yr-olds {\textgreater} 50 mm SL. Males seldom live beyond 3 yr or exceed 60 mm SL but females may live[Formula: see text] and attain 100 mm SL. Adult sex ratio is 2:3 in favor of females. Larger females are multibatch spawners, 2 batches/yr, with a mean fecundity of 100 eggs∙g
              −1
              ∙batch
              −1
              . Larval diet includes eggs and early stages of crustaceans dominated by Copepoda. juveniles and adults fed mainly of polychaetes, amphipods, euphausiids, and calanoid copepods found at depths {\textgreater} 100 m. Except for the postlarval and early juvenile stages lasting some 3 mo, the life cycle is pursued at depths {\textgreater} 150 m. Their bathypelagic existence in the Strait emphasizes predator avoidance coupled with low fecundity, slow growth, and short life span.},
	language = {en},
	number = {6},
	urldate = {2023-08-16},
	journal = {Canadian Journal of Fisheries and Aquatic Sciences},
	author = {Mason, J. C. and Phillips, A. C.},
	month = jun,
	year = {1985},
	note = {Number: 6},
	pages = {1144--1153},
}

@article{jude_recent_1985,
	title = {Recent {Changes} in the {Inshore} {Forage} {Fish} of {Lake} {Michigan}},
	volume = {42},
	issn = {0706-652X},
	url = {https://cdnsciencepub.com/doi/abs/10.1139/f85-142},
	doi = {10.1139/f85-142},
	abstract = {Concerns have been expressed that increasing predatory pressure by salmonids may change the forage fish community of Lake Michigan. A decline in alewife (Alosa pseudoharengus), the major forage fish, would be a forewarning of such a change. Our 1973–82 surveys showed that alewife declined 86\% in 1980–82; concurrently, rainbow smelt (Osmerus mordax) and yellow perch (Perca flavescens) increased threefold and fivefold, respectively. Spottail shiner (Notropis hudsonius) and trout-perch (Percopsis omiscomaycus) showed no long-term changes. Bloater (Coregonus hoyi) increased 24-fold since commercial fishing was prohibited in 1976. These trends imply that (1) alewife declined from predatory pressure, (2) alewife suppressed rainbow smelt and yellow perch, presumably by preying on their pelagic larvae, (3) alewife did not substantially affect spottail shiner and trout-perch, presumably because their demersal larvae escaped alewife predation, and (4) overfishing, more than the alewife, suppressed bloater.},
	number = {6},
	urldate = {2023-08-16},
	journal = {Canadian Journal of Fisheries and Aquatic Sciences},
	author = {Jude, David J. and Tesar, Frank J.},
	month = jun,
	year = {1985},
	note = {Number: 6
Publisher: NRC Research Press},
	pages = {1154--1157},
}

