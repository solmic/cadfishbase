@article{prokofiev_critical_2010,
	title = {Critical analysis of results of the revision of the genus \textit{{Chiasmodon}} made by {M}.{R}.{S}. {Melo} (2009) and a characteristic of new form \textit{{C}. niger}-complex from the {Indian} {Ocean} ({Perciformes}: {Chaismodontidae})},
	volume = {50},
	issn = {1555-6425},
	shorttitle = {Critical analysis of results of the revision of the genus {Chiasmodon} made by {M}.{R}.{S}. {Melo} (2009) and a characteristic of new form {C}. niger-complex from the {Indian} {Ocean} (perciformes},
	url = {https://doi.org/10.1134/S0032945210070027},
	doi = {10.1134/S0032945210070027},
	abstract = {Results of the revision of black swallowers (Chiasmodon) made by Melo (2009) are reconsidered. It is shown that separation of species by this author is based on individually varying characters investigated by this author on a limited number of fish, and some conclusions made in this study are based on factual mistakes. Validity of C. lavenbergi Prok. is restored, and C. asper Melo is included to its synonymy. It is shown that C. pluriradiatus Parr, as all other nominal species of the genus Chiasmodon, should be place in C. niger s. lato. Variation of C. niger-complex by dentition of gill arches and by some other meristic characters is pointed out. By armament of the gill apparatus, along with the typical form, forms α and β are discerned. The latter form is described in detail by two specimens from the eastern part of the Indian Ocean. It is found that form β corresponds to characters of the holotype of C. braueri while form α does not correspond to neither of the nominal taxa, attributed to C. niger s. l.},
	language = {en},
	number = {7},
	urldate = {2023-09-06},
	journal = {Journal of Ichthyology},
	author = {Prokofiev, A. M.},
	month = aug,
	year = {2010},
	note = {Number: 7},
	keywords = {systematics, Chiasmodon, nomenclature, variation},
	pages = {503--511},
}

@article{purcell_aggregations_2000,
	title = {Aggregations of the jellyfish \textit{{Aurelia} labiata}: abundance, distribution, association with age-0 walleye pollock, and behaviors promoting aggregation in {Prince} {William} {Sound}, {Alaska}, {USA}},
	volume = {195},
	issn = {0171-8630, 1616-1599},
	shorttitle = {Aggregations of the jellyfish {Aurelia} labiata},
	url = {http://www.int-res.com/abstracts/meps/v195/p145-158/},
	doi = {10.3354/meps195145},
	abstract = {Aurelia labiata medusae occurred in aggregations with hundreds to millions of jellyfish. The aggregations were widely distributed in inlets of Prince William Sound (PWS),Alaska. Aerial surveys of PWS in May to August in 1995, 1996, and 1997 showed marked interannual variation in the numbers of aggregations observed, from a minimum of 38 in 1997 to a maximum of 557 in 1996 Acoustic surveys showed that the aggregations extended from near-surface (0 to 5 m) to 15 m depth. Schools of young-of the-year walleye pollock Theragra chalcogramma were associated with A . labiata, both within and below the aggregations. All seine catches that contained juvenile pollock also contained jellyfish. Medusa swimming was analyzed from underwater videotapes in order to elucidate how aggregations might be formed and maintained. Medusae did not swim in circles in the aggregat i o n {\textasciitilde}M. edusae all swam vertically in the same direction, either up or down, in crowded parts of the aggregations, suggesting that they had become concentrated in flow features, like convergences, in the water column. Reduced swimming, due pnmarily to frequent collisions among medusae in the aggreg a t i o n {\textasciitilde} ,also may have caused the medusae to become concentrated. The potential advantages of aggregation include increased fertilization success, retention near shore where planula settlement sites and zooplankton prey may be more abundant, retention in convergences where zooplankton are concentrated, and reduced predation.},
	language = {en},
	urldate = {2023-09-06},
	journal = {Marine Ecology Progress Series},
	author = {Purcell, Jennifer E. and Brown, Evelyn D. and Stokesbury, Kevin D. E. and Haldorson, Lewis H. and Shirley, Thomas C.},
	year = {2000},
	pages = {145--158},
}

