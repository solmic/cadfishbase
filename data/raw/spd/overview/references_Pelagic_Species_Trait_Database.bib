@misc{noauthor_barracudina_2023-1,
	title = {Barracudina},
	copyright = {Creative Commons Attribution-ShareAlike License},
	url = {https://en.wikipedia.org/w/index.php?title=Barracudina&oldid=1149959285},
	abstract = {Barracudinas are any member of the marine mesopelagic fish family  Paralepididae: 50 or so extant species are found almost worldwide in deep waters.  Several genera are known only from fossils dating back to the Ypresian epoch.
