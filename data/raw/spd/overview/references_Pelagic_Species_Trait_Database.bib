@article{atkinson_aspects_2003,
	title = {Aspects of the biology of the burrowing shrimp \textit{{Alpheus} glaber} ({Olivi}) ({Decapoda}: {Caridea}: {Alpheidae}) from the {Central} {Adriatic}},
	volume = {57},
	issn = {0078-5326},
