@article{oliveira_lipid_2006,
	title = {Lipid analysis of fillets from giant grenadier (\textit{{Albatrossia} pectoralis}), arrow-tooth flounder (\textit{{Atheresthes} stomias}), {Pacific} cod (\textit{{Gadus} macrocephalus}) amd walleye pollock (\textit{{Theragra} chalcogramma})},
	volume = {17},
	issn = {1046-0756, 1745-4573},
	url = {https://onlinelibrary.wiley.com/doi/10.1111/j.1745-4573.2006.00030.x},
	doi = {10.1111/j.1745-4573.2006.00030.x},
	abstract = {In Alaska, walleye pollock (WP [Theragra chalcogramma]) and Paciﬁc cod (PC [Gadus macrocephalus]) are harvested in large amounts. There are also large biomasses of arrow-tooth ﬂounder (ATF [Atheresthes stomias]) and giant grenadier (GG [Albatrossia pectoralis]) available in Alaskan waters; however, these ﬁsh are underutilized. The objective of this study was to determine lipid content, lipid class distribution and fatty acid (FA) proﬁles of ﬁllets from these four ﬁsh species. Fat content and percent triacylglycerides (TAG) in ATF was signiﬁcantly higher than in other species, and percent phospholipids (PL) was lower (P Ͻ 0.05). PC had the highest levels of omega-3 (w-3) FA, whereas ATF had the lowest. The ratio of w-3/omega-6 (w-6) FA was signiﬁcantly higher in ATF than in other species. Percent polyunsaturated and saturated FA’s were equivalent in ATF; however, other species showed at least twice as much polyunsaturated FA as saturated FA. This study provided comparisons of the lipid characteristics in the two most abundant white ﬁsh harvested in Alaska and two other abundant but underutilized species.},
	language = {en},
	number = {1},
	urldate = {2023-05-08},
	journal = {Journal of Muscle Foods},
	author = {Oliveira, A.C.M. and Bechtel, P.J.},
	month = jan,
	year = {2006},
	note = {Number: 1},
	pages = {20--33},
}

